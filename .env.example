# HTTP
PORT=8080
WEB_DIR=./static

# PostgreSQL
DATABASE_URL=postgres://mediauser:mediapass@localhost:5432/mediacloud?sslmode=disable

# Storage root. Originals, thumbnails and HLS output live under this directory.
STORAGE_PATH=./data/media

# Auth. If empty, a random secret is generated at boot (tokens won't survive restarts).
JWT_SECRET=change-me-to-a-long-random-string
TOKEN_TTL=72h

# Media pipeline
MAX_WORKERS=2
JOB_QUEUE_SIZE=128
PROCESS_TIMEOUT=45m
MAX_UPLOAD_BYTES=10737418240
HLS_SEGMENT_SECONDS=6
# H.264 encoder: auto (VideoToolbox on macOS, libx264 elsewhere) | videotoolbox | none
HWACCEL=auto
# Abandoned chunked uploads are reclaimed after this long
UPLOAD_TTL=48h

# External binaries (only override if not on PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
